PORT=3000
NETWORK=mainnet
DB_PATH=./data/wallet.db

# TON
TONCENTER_MAINNET_URL=https://toncenter.mytonwallet.org
TONCENTER_TESTNET_URL=https://toncenter-testnet.mytonwallet.org
TONCENTER_API_KEY=

# EVM
EVM_API_URL=https://evmapi.mytonwallet.org

# Solana
SOLANA_RPC_URL=https://solana-rpc.publicnode.com

# TRON
TRON_API_URL=https://api.trongrid.io
TRON_API_KEY=

# Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Monitor
MONITOR_FALLBACK_INTERVAL_MS=30000
WS_RECONNECT_MAX_MS=30000

# Security — never set to true in production
EXPOSE_SEED_PHRASE=false
